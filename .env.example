# Flask Environment Configuration
# Copy this file to .env and fill in your values

# DATABASE CONFIGURATION
# Leave commented for SQLite (auto-creates resume_builder.db)
# For PostgreSQL: DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/resume_builder
# DATABASE_URL=

# JWT CONFIGURATION
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# FLASK SETTINGS
FLASK_ENV=development
FLASK_DEBUG=1

# AI API KEYS (Free tiers available)
# Get Groq key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Get Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here


